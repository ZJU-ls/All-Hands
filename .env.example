# ============================================================
# allhands · .env.example
#
# Copy to `.env` before `docker compose up`. docker-compose.yml reads these
# variables and forwards them to the backend as ALLHANDS_* env vars.
# Nothing in this file is ever committed.
# ============================================================

# ---- LLM (required) -----------------------------------------
# Any OpenAI-compatible endpoint works: OpenAI, DeepSeek, Groq, local LMStudio, etc.
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
DEFAULT_MODEL_REF=openai/gpt-4o-mini

# ---- Alibaba Cloud Bailian / DashScope (optional) -----------
# OpenAI-compatible endpoint. Recommended coding model: qwen-coder-plus
# Get key at: https://bailian.console.aliyun.com/
ALLHANDS_DASHSCOPE_API_KEY=

# ---- LangFuse (self-hosted via docker compose) ---------------
# On first run these are empty — LangFuse will serve its UI at :3001.
# Create a user + project inside LangFuse, then paste the keys back here
# and restart the backend container.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Strong dev-local secret. Change for any non-local deployment.
LANGFUSE_DB_PASSWORD=langfuse
LANGFUSE_NEXTAUTH_SECRET=change-me-dev-secret
LANGFUSE_SALT=change-me-dev-salt

# ---- App tuning (optional) ----------------------------------
ALLHANDS_ENV=dev

# ---- Knowledge Base ----------------------------------------
# Default embedding model for newly created KBs. Per-KB override is
# allowed at create time. Schemes:
#   mock:hash-<dim>     — deterministic, dev-only, always available
#   openai:<model>      — needs ALLHANDS_OPENAI_API_KEY
#                         e.g. text-embedding-3-small (1536d) / -3-large (3072d)
#   bailian:<model>     — needs ALLHANDS_DASHSCOPE_API_KEY
#                         e.g. text-embedding-v3 (1024d) / -v4 (1024d)
ALLHANDS_KB_DEFAULT_EMBEDDING_MODEL_REF=mock:hash-64
ALLHANDS_KB_EMBEDDING_BATCH_SIZE=64
