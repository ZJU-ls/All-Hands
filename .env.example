# ============================================================
# allhands · .env.example
#
# Copy to `.env` before `docker compose up`. docker-compose.yml reads these
# variables and forwards them to the backend as ALLHANDS_* env vars.
# Nothing in this file is ever committed.
# ============================================================

# ---- LLM (required) -----------------------------------------
# Any OpenAI-compatible endpoint works: OpenAI, DeepSeek, Groq, local LMStudio, etc.
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
DEFAULT_MODEL_REF=openai/gpt-4o-mini

# ---- LangFuse (self-hosted via docker compose) ---------------
# On first run these are empty — LangFuse will serve its UI at :3001.
# Create a user + project inside LangFuse, then paste the keys back here
# and restart the backend container.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Strong dev-local secret. Change for any non-local deployment.
LANGFUSE_DB_PASSWORD=langfuse
LANGFUSE_NEXTAUTH_SECRET=change-me-dev-secret
LANGFUSE_SALT=change-me-dev-salt

# ---- App tuning (optional) ----------------------------------
ALLHANDS_ENV=dev
