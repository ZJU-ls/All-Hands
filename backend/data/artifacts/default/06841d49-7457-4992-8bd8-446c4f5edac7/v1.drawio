<mxfile host="app.diagrams.net">
  <diagram name="Platform Architecture">
    <mxGraphModel dx="1024" dy="768" grid="1" gridSize="10" pageWidth="1100" pageHeight="850">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        
        <!-- User Layer -->
        <mxCell id="n_user" value="用户终端 (Web/Mobile)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="450" y="40" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- Access Layer -->
        <mxCell id="n_gateway" value="API 网关 / 负载均衡" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="450" y="140" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- Service Layer -->
        <mxCell id="n_service_bg" value="" style="rounded=0;whiteSpace=wrap;html=1;dashed=1;fillColor=none;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="150" y="240" width="800" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="n_svc_label" value="核心服务层" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="160" y="250" width="100" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="n_svc_1" value="制品管理" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="200" y="280" width="120" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="n_svc_2" value="质量管控" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="360" y="280" width="120" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="n_svc_3" value="可视化引擎" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="520" y="280" width="120" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="n_svc_4" value="智能助手" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="680" y="280" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- Data Layer -->
        <mxCell id="n_data_bg" value="" style="rounded=0;whiteSpace=wrap;html=1;dashed=1;fillColor=none;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="150" y="420" width="800" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="n_data_label" value="数据持久层" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="160" y="430" width="100" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="n_db_1" value="对象存储 (OSS)" style="shape=cylinder;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="220" y="460" width="80" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="n_db_2" value="关系数据库 (RDS)" style="shape=cylinder;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="380" y="460" width="80" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="n_db_3" value="向量数据库" style="shape=cylinder;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="540" y="460" width="80" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="n_db_4" value="缓存 (Redis)" style="shape=cylinder;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="700" y="460" width="80" height="60" as="geometry"/>
        </mxCell>

        <!-- Edges -->
        <mxCell id="e1" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="n_user" target="n_gateway">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e2" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="n_gateway" target="n_svc_2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e3" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="n_svc_2" target="n_db_2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e4" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="n_svc_1" target="n_db_1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e5" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="n_svc_3" target="n_db_3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>