<mxfile host="app.diagrams.net" agent="allhands-design">
  <diagram name="brand-flow">
    <mxGraphModel dx="900" dy="700" grid="1" gridSize="10" pageWidth="1100" pageHeight="850" math="0" shadow="1">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ===== 标题(渐变文本不能在 drawio 直接做 · 用主色实底) ===== -->
        <mxCell id="title" value="All Hands 能力处理流程"
                style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=22;fontStyle=1;fontColor=#0A5BFF;"
                vertex="1" parent="1">
          <mxGeometry x="280" y="20" width="540" height="40" as="geometry"/>
        </mxCell>

        <!-- ===== 入口 · 蓝(primary 软背 + primary 边) ===== -->
        <mxCell id="entry" value="用户需求解析"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E5EDFF;strokeColor=#0A5BFF;strokeWidth=1.5;shadow=1;fontSize=13;fontColor=#0A5BFF;fontStyle=1;"
                vertex="1" parent="1">
          <mxGeometry x="80" y="160" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- ===== 处理 1 · 中性白 + hairline ===== -->
        <mxCell id="step1" value="web_research / file_writing"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B9C4D4;strokeWidth=1;shadow=1;fontSize=12;fontColor=#141A26;"
                vertex="1" parent="1">
          <mxGeometry x="320" y="160" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- ===== 处理 2 ===== -->
        <mxCell id="step2" value="Brand Blue 设计校准"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B9C4D4;strokeWidth=1;shadow=1;fontSize=12;fontColor=#141A26;"
                vertex="1" parent="1">
          <mxGeometry x="560" y="160" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- ===== 决策 · 黄(warning 软背) ===== -->
        <mxCell id="decision" value="内容复杂度"
                style="rhombus;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=1.5;shadow=1;fontSize=12;fontColor=#92400E;"
                vertex="1" parent="1">
          <mxGeometry x="800" y="148" width="160" height="84" as="geometry"/>
        </mxCell>

        <!-- ===== 成功路径 · 绿 ===== -->
        <mxCell id="ok" value="HTML / Drawio 渲染"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#0FA57A;strokeWidth=1.5;shadow=1;fontSize=12;fontColor=#065F46;fontStyle=1;"
                vertex="1" parent="1">
          <mxGeometry x="640" y="320" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- ===== 失败路径 · 红 ===== -->
        <mxCell id="fail" value="复杂后端逻辑"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;strokeWidth=1.5;shadow=1;dashed=1;fontSize=12;fontColor=#7F1D1D;"
                vertex="1" parent="1">
          <mxGeometry x="900" y="320" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- ===== 数据存储 · 紫(role-lead) ===== -->
        <mxCell id="db" value="Artifact 存档"
                style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#EDE9FE;strokeColor=#6366F1;strokeWidth=1.5;shadow=1;fontSize=12;fontColor=#3730A3;"
                vertex="1" parent="1">
          <mxGeometry x="380" y="320" width="120" height="80" as="geometry"/>
        </mxCell>

        <!-- ===== Edges ===== -->
        <mxCell id="e1" style="endArrow=classic;html=1;rounded=1;strokeColor=#5C667A;strokeWidth=1.5;" edge="1" parent="1" source="entry" target="step1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e2" style="endArrow=classic;html=1;rounded=1;strokeColor=#5C667A;strokeWidth=1.5;" edge="1" parent="1" source="step1" target="step2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e3" style="endArrow=classic;html=1;rounded=1;strokeColor=#5C667A;strokeWidth=1.5;" edge="1" parent="1" source="step2" target="decision">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e4" value="静态/可视化" style="endArrow=classic;html=1;rounded=1;strokeColor=#0FA57A;strokeWidth=2;fontColor=#0FA57A;fontStyle=1;" edge="1" parent="1" source="decision" target="ok">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e5" value="动态逻辑" style="endArrow=classic;html=1;rounded=1;strokeColor=#DC2626;strokeWidth=2;fontColor=#DC2626;fontStyle=1;" edge="1" parent="1" source="decision" target="fail">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e6" style="endArrow=open;html=1;rounded=1;strokeColor=#8B96AB;strokeWidth=1;dashed=1;" edge="1" parent="1" source="step2" target="db">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>