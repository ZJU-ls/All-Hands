[importlinter]
root_package = allhands
include_external_packages = True

[importlinter:contract:layered]
name = Layered architecture (strict top-down)
type = layers
layers =
    allhands.api
    allhands.services
    allhands.execution
    allhands.observability
    allhands.persistence
    allhands.core

[importlinter:contract:core-no-frameworks]
name = core must not import frameworks
type = forbidden
source_modules =
    allhands.core
forbidden_modules =
    sqlalchemy
    fastapi
    starlette
    langgraph
    langchain
    langchain_core
    langchain_openai
    langfuse
    openai
    anthropic
    mcp

[importlinter:contract:persistence-no-frameworks]
name = persistence must not import api/service/execution
type = forbidden
source_modules =
    allhands.persistence
forbidden_modules =
    allhands.api
    allhands.services
    allhands.execution
    fastapi
    langgraph
    langchain

[importlinter:contract:langgraph-only-in-execution]
# ADR 0014 R1 + ADR 0011 principle 3 · LangGraph types must stay behind the
# allhands.execution boundary. Only the runner + checkpointer factory in
# execution/ may directly touch langgraph.*; api/services/core reach it via
# AgentEvent types or Any-typed ports (ChatService.checkpointer: Any | None).
# `allow_indirect_imports` = True keeps the services → execution → langgraph
# transitive path legal (the whole point of layering), while flagging any
# direct ``from langgraph import ...`` added to a service / api / core file.
name = langgraph direct imports only in allhands.execution (ADR 0014 R1)
type = forbidden
source_modules =
    allhands.services
    allhands.api
    allhands.core
forbidden_modules =
    langgraph
allow_indirect_imports = True
