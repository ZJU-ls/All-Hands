[importlinter]
root_package = allhands
include_external_packages = True

[importlinter:contract:layered]
name = Layered architecture (strict top-down)
type = layers
layers =
    allhands.api
    allhands.services
    allhands.execution
    allhands.observability
    allhands.persistence
    allhands.core

[importlinter:contract:core-no-frameworks]
name = core must not import frameworks
type = forbidden
source_modules =
    allhands.core
forbidden_modules =
    sqlalchemy
    fastapi
    starlette
    langgraph
    langchain
    langchain_core
    langchain_openai
    langfuse
    openai
    anthropic
    mcp

[importlinter:contract:persistence-no-frameworks]
name = persistence must not import api/service/execution
type = forbidden
source_modules =
    allhands.persistence
forbidden_modules =
    allhands.api
    allhands.services
    allhands.execution
    fastapi
    langgraph
    langchain

[importlinter:contract:no-langgraph-anywhere]
# ADR 0018 · LangGraph fully removed from the orchestration layer. Custom
# AgentLoop in execution/agent_loop.py drives the agent; all suspend/resume
# flows through DeferredSignal in tool_pipeline. langgraph and
# langgraph-checkpoint-sqlite are also removed from project deps. This
# contract prevents accidental reintroduction.
name = no langgraph imports anywhere (ADR 0018)
type = forbidden
source_modules =
    allhands
forbidden_modules =
    langgraph
    langgraph_checkpoint_sqlite
