    "about": {
      "title": "About",
      "tagline": "One for All — an open-source, self-hosted digital workforce platform.",
      "description": "Design, dispatch, and observe a team of digital employees by chatting with the Lead Agent. Every capability is registered as a Tool; the front-end menus are just entry points, and the backend follows the Tool First principle.",
      "version": "v0 · mvp",
      "facts": {
        "principles": {
          "label": "Core principles",
          "body": "Tool First · Unified React Agent · Pure Query Loop · Skill progressive loading · Subagent composition · L4 guardrails"
        },
        "employees": {
          "label": "Digital employees",
          "body": "Every agent is just configuration (model · skills · tools · system prompt) — no mode field"
        },
        "guardrails": {
          "label": "Guardrails",
          "body": "Tools must declare scope · WRITE requires confirmation by default · IRREVERSIBLE goes through double confirmation"
        }
      }
    },
    "review": {
      "title": "Review",
      "headerTitle": "Review · 3-stage delivery gates",
      "headerSubtitle": "These three gates push a spec from “it's written” to “it can ship to users.” Each has its own persona, artifacts, and exit conditions. Click a Meta Tool name below to have Lead trigger it from chat (with confirmation).",
